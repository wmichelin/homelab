# Dynamic DNS configuration
DDNS_PASSWORD=your_namecheap_ddns_password_here

# Subdomain for exposing services (use a random string for security)
HOMELAB_SUBDOMAIN=your_random_subdomain_here

# Your domain name
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications
EMAIL=your-email@domain.com

# Grafana admin credentials (only applied on first init of the grafana volume)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Hubitat exporter: hub devices API URI and access token
HE_URI=http://your_hub_ip/apps/api/20/devices
HE_TOKEN=your_hubitat_maker_api_token_here